{
  "name": "mastodon-bird-ui",
  "version": "4.0.0",
  "description": "",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "stylelint \"src/**/*.scss\"",
    "lint:watch": "onchange \"src/**/*.scss\" -- npm run lint",
    "dev": "npm-run-all --parallel watch sync lint:watch",
    "dev:stars": "npm-run-all --parallel watch:stars sync:stars lint:watch",
    "dev:accessible": "npm-run-all --parallel watch:accessible sync:accessible lint:watch",
    "dev:accessible-plus": "npm-run-all --parallel watch:accessible-plus sync:accessible-plus lint:watch",
    "dev:accessible-hide-finnish": "npm-run-all --parallel watch:accessible-hide-finnish sync:accessible-hide-finnish lint:watch",
    "dev:light": "npm-run-all --parallel watch:light sync:light lint:watch",
    "dev:light-stars": "npm-run-all --parallel watch:light-stars sync:light-stars lint:watch",
    "dev:mementomods": "npm-run-all --parallel watch sync:mementomods lint:watch",
    "dev:mastodon": "npm-run-all --parallel watch sync:mastodon lint:watch",
    "watch": "parcel watch src/mastodon-bird-ui.scss --dist-dir dist --public-url /mastodon-bird-ui",
    "watch:stars": "parcel watch src/mastodon-bird-ui-stars.scss --dist-dir dist --public-url /mastodon-bird-ui",
    "watch:accessible": "parcel watch src/mastodon-bird-ui-accessible.scss --dist-dir dist --public-url /mastodon-bird-ui",
    "watch:accessible-plus": "parcel watch src/mastodon-bird-ui-accessible-plus.scss --dist-dir dist --public-url /mastodon-bird-ui",
    "watch:accessible-hide-finnish": "parcel watch src/mastodon-bird-ui-accessible-hide-finnish.scss --dist-dir dist --public-url /mastodon-bird-ui",
    "watch:light": "parcel watch src/mastodon-bird-ui-light.scss --dist-dir dist --public-url /mastodon-bird-ui",
    "watch:light-stars": "parcel watch src/mastodon-bird-ui-light-stars.scss --dist-dir dist --public-url /mastodon-bird-ui",
    "sync": "browser-sync start --config bs-config.js",
    "sync:stars": "VARIANT=mastodon-bird-ui-stars browser-sync start --config bs-config.js",
    "sync:accessible": "VARIANT=mastodon-bird-ui-accessible browser-sync start --config bs-config.js",
    "sync:accessible-plus": "VARIANT=mastodon-bird-ui-accessible-plus browser-sync start --config bs-config.js",
    "sync:accessible-hide-finnish": "VARIANT=mastodon-bird-ui-accessible-hide-finnish browser-sync start --config bs-config.js",
    "sync:light": "VARIANT=mastodon-bird-ui-light browser-sync start --config bs-config.js",
    "sync:light-stars": "VARIANT=mastodon-bird-ui-light-stars browser-sync start --config bs-config.js",
    "sync:mementomods": "browser-sync start --config bs-config.mementomods.js",
    "sync:mastodon": "browser-sync start --config bs-config.mastodon.js",
    "build": "npm run build:custom-css",
    "build:custom-css": "parcel build src/mastodon-bird-ui.scss --dist-dir dist --no-source-maps --no-optimize && npm run banner",
    "banner": "for f in dist/*.css; do echo \"/* Mastodon Bird UI v$npm_package_version - https://github.com/ronilaukkarinen/mastodon-bird-ui */\" | cat - \"$f\" > temp && mv temp \"$f\"; done",
    "clean": "rm -rf dist .parcel-cache"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@parcel/transformer-sass": "^2.16.1",
    "browser-sync": "^3.0.4",
    "http-proxy-middleware": "^3.0.5",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "parcel": "^2.16.1",
    "postcss": "^8.4.47",
    "postcss-cli": "^11.0.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.6.2",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^6.0.3",
    "stylelint-value-no-unknown-custom-properties": "^6.1.0"
  }
}
